# Aegis Backend Configuration
# Copy this file to .env and fill in your values.

# DeepSeek API key for LLM-powered contract generation and auditing
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# DeepSeek model to use (default: deepseek-coder)
DEEPSEEK_MODEL=deepseek-coder

# Server port (default: 3001)
PORT=3001

# x402 Payment Receiver Wallet (for paid endpoints — optional for now)
# RECEIVER_WALLET_PRIVATE_KEY=
# CALLBACK_BASE_URL=https://aegis-dzyd.onrender.com

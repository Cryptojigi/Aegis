# Aegis Backend Configuration
# Copy this file to .env and fill in your values.

# DeepSeek API key for LLM-powered contract generation and auditing
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# DeepSeek model to use (default: deepseek-coder)
DEEPSEEK_MODEL=deepseek-coder

# Server port (default: 3001)
PORT=3001

# ---------------------------------------------------------------------------
# x402 Payment Configuration
# Uncomment and fill in to enable paid endpoints.
# ---------------------------------------------------------------------------

# Your receiving wallet address (where fees are sent)
# RECEIVING_WALLET_ADDRESS=0x735C8004Fa184D9D38Cf098751F2d7e98f0A3e9A

# Admin bypass key — set this and send x-admin-bypass header to skip payment
# ADMIN_BYPASS_KEY=your-secret-bypass-key

# X Layer RPC URL (default: https://rpc.xlayer.tech)
# RPC_URL=https://rpc.xlayer.tech

# USDT contract address on X Layer (default is the official bridge address)
# USDT_CONTRACT_ADDRESS=0x1e4a5963abfd975d8c9021ce480b42188849d41d
